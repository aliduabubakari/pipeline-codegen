# ---------------------------------------------------------------------------
# Global LLM defaults (used by opos-generate in llm-assisted mode)
# ---------------------------------------------------------------------------
# One of: openai, openrouter, deepinfra, deepseek, claude, ollama, stub
LLM_PROVIDER=stub

# Generic overrides (applies to selected provider unless provider-specific
# values below are explicitly used by your workflow)
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=256
LLM_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# Provider credentials expected by pipeline-codegen
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPINFRA_API_TOKEN=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional provider-specific model/base URL overrides
# (used by config loader when LLM_MODEL / LLM_BASE_URL are not set)
# ---------------------------------------------------------------------------
OPENAI_MODEL=
OPENAI_BASE_URL=

OPENROUTER_MODEL=
OPENROUTER_BASE_URL=

DEEPINFRA_MODEL=
DEEPINFRA_BASE_URL=

DEEPSEEK_MODEL=
DEEPSEEK_BASE_URL=

CLAUDE_MODEL=
CLAUDE_BASE_URL=

OLLAMA_MODEL=
OLLAMA_BASE_URL=

# ---------------------------------------------------------------------------
# Hosted KB service integration (pipeline-codegen client side)
# ---------------------------------------------------------------------------
# Pass these values to CLI flags for remote knowledge lookup:
# --kb-service-url, --kb-service-token, --kb-timeout-seconds
KB_SERVICE_URL=
KB_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Hosted KB service runtime (backend-only; not for end users)
# ---------------------------------------------------------------------------
# Service auth token accepted by kb-service API.
KB_SERVICE_TOKEN=dev-token
# Local storage defaults for kb-service process (tmp paths are default;
# override if you need persistent storage).
KB_OBJECT_STORE_DIR=/tmp/pipeline_codegen_kb/object_store
KB_SQLITE_PATH=/tmp/pipeline_codegen_kb/metadata.db
# Exa retrieval configuration (backend-owned credentials).
KB_EXA_SEARCH_TYPE=deep
KB_EXA_NUM_RESULTS=8
KB_MIN_TRUSTED_SOURCES=1
KB_MIN_CONFIDENCE=0.35
KB_SERVICE_TRUSTED_DOMAINS=docs.airflow.apache.org,docs.prefect.io,docs.dagster.io,kestra.io,github.com
# Backend secret only:
EXA_API_KEY=
